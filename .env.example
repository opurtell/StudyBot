# Model names per provider and tier
# Edit these to update available models without changing code
# Copy to .env and modify as needed

# Z.ai models
ZAI_MODEL_LOW=glm-4.7-flash
ZAI_MODEL_MEDIUM=glm-4.7
ZAI_MODEL_HIGH=glm-5

# Anthropic models
ANTHROPIC_MODEL_LOW=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_MEDIUM=claude-sonnet-4.6
ANTHROPIC_MODEL_HIGH=claude-opus-4.6

# Google models
GOOGLE_MODEL_LOW=gemini-3.1-flash-lite-preview
GOOGLE_MODEL_MEDIUM=gemini-3-flash-preview
GOOGLE_MODEL_HIGH=gemini-2.5-pro
